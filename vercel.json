{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "api/**/*.[jt]s": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "outputDirectory": "dist/client",
  "rewrites": [
    {
      "source": "/*",
      "destination": "/api/$1"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
